#!/usr/bin/env bash
# Ordinary-user Taiji Agent CLI launcher. It uses each user's product runtime
# state and does not read the desktop app's temporary API key.
set -euo pipefail

APP_ROOT="${TAIJI_AGENT_ROOT:-/opt/taiji-agent}"
TAIJI_PYTHON="$APP_ROOT/runtime/agent/venv/bin/python"
RUNTIME_ENV="$APP_ROOT/scripts/runtime-env.sh"

if [ ! -x "$TAIJI_PYTHON" ]; then
  echo "Taiji Agent CLI runtime not found: $TAIJI_PYTHON" >&2
  exit 1
fi

if [ -f "$RUNTIME_ENV" ]; then
  export TAIJI_AGENT_ROOT="$APP_ROOT"
  export TAIJI_AGENT_USE_USER_DIRS="${TAIJI_AGENT_USE_USER_DIRS:-1}"
  # shellcheck source=/dev/null
  source "$RUNTIME_ENV"
else
  export TAIJI_RUNTIME_HOME="${TAIJI_RUNTIME_HOME:-$HOME/.local/share/taiji-agent/runtime-home}"
  export TAIJI_WORKSPACE="${TAIJI_WORKSPACE:-$HOME/.local/share/taiji-agent/workspace}"
fi

exec "$TAIJI_PYTHON" -m taiji_runtime.main "$@"
