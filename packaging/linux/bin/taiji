#!/usr/bin/env bash
# Ordinary-user Taiji Agent CLI launcher. It intentionally uses each user's
# own ~/.hermes state and does not read the desktop app's temporary API key.
set -euo pipefail

APP_ROOT="${TAIJI_AGENT_ROOT:-/opt/taiji-agent}"
HERMES_BIN="$APP_ROOT/sources/hermes-agent/venv/bin/hermes"

if [ ! -x "$HERMES_BIN" ]; then
  echo "Taiji Agent CLI runtime not found: $HERMES_BIN" >&2
  exit 1
fi

export HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
export HERMES_WORKSPACE="${HERMES_WORKSPACE:-$PWD}"
exec "$HERMES_BIN" "$@"
