#!/usr/bin/env bash
# Installation/runtime verifier for Taiji Agent desktop packages.
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=runtime-env.sh
source "$SCRIPT_DIR/runtime-env.sh"

AGENT_API_HOST="${AGENT_API_HOST:-127.0.0.1}"
AGENT_API_PORT="${AGENT_API_PORT:-18642}"
WEBUI_HOST="${WEBUI_HOST:-127.0.0.1}"
WEBUI_PORT="${WEBUI_PORT:-18787}"

ok_count=0
warn_count=0
fail_count=0

ok() { printf '[OK] %s\n' "$*"; ok_count=$((ok_count + 1)); }
warn() { printf '[WARN] %s\n' "$*"; warn_count=$((warn_count + 1)); }
fail() { printf '[FAIL] %s\n' "$*"; fail_count=$((fail_count + 1)); }

packaged_install=0
if [ "$LAB_DIR" = "/opt/taiji-agent" ]; then
  packaged_install=1
fi

runtime_issue() {
  if [ "$packaged_install" -eq 1 ]; then
    fail "$*"
  else
    warn "$*"
  fi
}

http_code() {
  curl -sS -o /dev/null -w '%{http_code}' "$1" 2>/dev/null
}

python_bin() {
  if [ -x "$AGENT_DIR/venv/bin/python" ]; then
    printf '%s\n' "$AGENT_DIR/venv/bin/python"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  else
    printf '\n'
  fi
}

verify_packaged_config() {
  local py template target
  py="$(python_bin)"
  template="$LAB_DIR/config/taiji-default-config.yaml"
  target="$TAIJI_RUNTIME_HOME/config.yaml"
  [ -n "$py" ] || return 1
  "$py" - "$template" "$target" <<'PY'
from pathlib import Path
import sys

try:
    import yaml
except Exception as exc:
    print(f"yaml import failed: {exc}", file=sys.stderr)
    raise SystemExit(1)

template_path = Path(sys.argv[1])
target_path = Path(sys.argv[2])
if not template_path.exists():
    print(f"missing packaged config template: {template_path}", file=sys.stderr)
    raise SystemExit(1)
if not target_path.exists():
    print(f"missing active user config: {target_path}", file=sys.stderr)
    raise SystemExit(1)

template = yaml.safe_load(template_path.read_text(encoding="utf-8")) or {}
target = yaml.safe_load(target_path.read_text(encoding="utf-8")) or {}
template_visibility = ((template.get("webui") or {}).get("feature_visibility") or {})
target_visibility = ((target.get("webui") or {}).get("feature_visibility") or {})
if template_visibility != target_visibility:
    print("active config feature_visibility does not match packaged template", file=sys.stderr)
    raise SystemExit(1)
model = target.get("model") if isinstance(target.get("model"), dict) else {}
provider = str(model.get("provider") or "").strip()
model_id = str(model.get("default") or model.get("model") or "").strip()
if not provider or not model_id:
    print("active config main model provider/model is empty", file=sys.stderr)
    raise SystemExit(1)
image = target.get("image_gen") if isinstance(target.get("image_gen"), dict) else {}
print(f"active config model={provider}/{model_id}")
print(f"active config image_gen={image.get('provider') or '-'}/{image.get('model') or '-'}")
PY
}

verify_webui_api_payloads() {
  local py base_url
  py="$(python_bin)"
  base_url="http://$WEBUI_HOST:$WEBUI_PORT"
  [ -n "$py" ] || return 1
  "$py" - "$base_url" <<'PY'
import json
import sys
import urllib.request

base_url = sys.argv[1].rstrip("/")

def fetch(path):
    with urllib.request.urlopen(base_url + path, timeout=5) as response:
        if response.status < 200 or response.status >= 300:
            raise RuntimeError(f"{path} HTTP {response.status}")
        return json.loads(response.read().decode("utf-8"))

settings = fetch("/api/settings")
visibility = settings.get("ui_visibility") or {}
composer = visibility.get("composer") or {}
nav = visibility.get("nav") or {}
if composer.get("workspace_files") is not False:
    raise SystemExit("composer.workspace_files is not hidden in /api/settings")
if nav.get("kanban") is not False or nav.get("skills") is not False:
    raise SystemExit("expected packaged nav visibility is not reflected in /api/settings")

model_config = fetch("/api/model-config")
main = model_config.get("main") or {}
providers = model_config.get("providers") or []
if not main.get("provider") or not main.get("model"):
    raise SystemExit("main provider/model is empty in /api/model-config")
if not isinstance(providers, list) or not providers:
    raise SystemExit("providers list is empty in /api/model-config")
print(f"api model={main.get('provider')}/{main.get('model')} providers={len(providers)}")
PY
}

echo "Taiji Agent native verification"
echo "Install root: $LAB_DIR"
echo "Config file : $TAIJI_ENV_FILE"
echo "Runtime home: $TAIJI_RUNTIME_HOME"
echo "Workspace   : $TAIJI_WORKSPACE"
echo "Log dir     : $LOG_DIR"
echo

arch="$(uname -m 2>/dev/null || true)"
case "$arch" in
  x86_64|amd64) ok "CPU architecture supported: $arch" ;;
  arm64|aarch64) warn "Current machine is $arch; Hygon/UOS target package must be x86_64/amd64" ;;
  *) fail "Unsupported or unknown CPU architecture: ${arch:-unknown}" ;;
esac

if [ -d "$AGENT_DIR" ] && { [ -f "$AGENT_DIR/taiji_runtime/main.py" ] || [ -f "$AGENT_DIR/taiji_runtime/main.pyc" ]; }; then
  ok "Agent runtime exists: $AGENT_DIR"
else
  fail "Agent runtime missing: $AGENT_DIR"
fi

if [ -d "$WEBUI_DIR" ] && { [ -f "$WEBUI_DIR/server.py" ] || [ -f "$WEBUI_DIR/server.pyc" ]; }; then
  ok "Web runtime exists: $WEBUI_DIR"
else
  fail "Web runtime missing: $WEBUI_DIR"
fi

for script in start-agent.sh start-webui.sh stop-all.sh runtime-env.sh; do
  if [ -f "$SCRIPT_DIR/$script" ]; then
    ok "Runtime script exists: $script"
  else
    fail "Runtime script missing: $SCRIPT_DIR/$script"
  fi
done

if [ -x "$AGENT_DIR/venv/bin/python" ]; then
  ok "Bundled Agent Python runtime exists"
  if (cd "$AGENT_DIR" && "$AGENT_DIR/venv/bin/python" -m taiji_runtime.main --help >/dev/null 2>&1); then
    ok "Taiji runtime module entrypoint works"
  else
    runtime_issue "Taiji runtime module entrypoint failed"
  fi
else
  runtime_issue "Bundled Agent Python runtime not found; run setup-local.sh in source mode or rebuild Linux package with venv included"
fi

desktop_app="$LAB_DIR/apps/taiji-desktop"
if [ ! -f "$desktop_app/package.json" ] && [ -f "$LAB_DIR/../apps/taiji-desktop/package.json" ]; then
  desktop_app="$(cd "$LAB_DIR/.." && pwd)/apps/taiji-desktop"
fi
if [ -f "$desktop_app/package.json" ] && [ -f "$desktop_app/src/main.js" ]; then
  ok "Electron desktop app files exist: $desktop_app"
else
  runtime_issue "Electron desktop app files not found under install root: $desktop_app"
fi

electron_bin="$desktop_app/node_modules/electron/dist/electron"
if [ -x "$electron_bin" ]; then
  ok "Electron runtime exists: $electron_bin"
  if command -v file >/dev/null 2>&1; then
    electron_file="$(file "$electron_bin" 2>/dev/null || true)"
    case "$electron_file" in
      *ELF*64-bit*x86-64*|*ELF*64-bit*X86-64*|*ELF*64-bit*80386*)
        ok "Electron runtime is Linux x86_64 ELF"
        ;;
      *)
        runtime_issue "Electron runtime is not Linux x86_64 ELF: ${electron_file:-unknown file type}"
        ;;
    esac
  fi
  if command -v ldd >/dev/null 2>&1; then
    ldd_output="$(ldd "$electron_bin" 2>&1 || true)"
    if printf '%s\n' "$ldd_output" | grep -q 'not found'; then
      printf '%s\n' "$ldd_output" >&2
      runtime_issue "Electron runtime has missing shared libraries marked as not found"
    else
      ok "Electron runtime ldd check found no missing shared libraries"
    fi
  else
    warn "ldd not found; Electron shared library check skipped"
  fi
else
  runtime_issue "Electron runtime missing or not executable: $electron_bin"
fi

if command -v taiji-agent >/dev/null 2>&1; then
  ok "Global desktop launcher exists: $(command -v taiji-agent)"
else
  warn "Global desktop launcher taiji-agent not found in PATH"
fi

if command -v taiji >/dev/null 2>&1; then
  ok "Global CLI launcher exists: $(command -v taiji)"
else
  warn "Global CLI launcher taiji not found in PATH"
fi

if [ -f /usr/share/applications/taiji-agent.desktop ]; then
  ok "Desktop entry installed: /usr/share/applications/taiji-agent.desktop"
  if grep -qx 'Exec=/usr/bin/taiji-agent' /usr/share/applications/taiji-agent.desktop \
    && grep -qx 'Icon=taiji-agent' /usr/share/applications/taiji-agent.desktop \
    && grep -qx 'Terminal=false' /usr/share/applications/taiji-agent.desktop; then
    ok "Desktop entry points to the packaged launcher and icon"
  else
    runtime_issue "Desktop entry is missing expected Exec/Icon/Terminal settings"
  fi
else
  runtime_issue "Desktop entry not found at /usr/share/applications/taiji-agent.desktop"
fi

if [ -f /usr/share/icons/hicolor/512x512/apps/taiji-agent.png ]; then
  ok "Desktop icon installed: /usr/share/icons/hicolor/512x512/apps/taiji-agent.png"
else
  runtime_issue "Desktop icon not found at /usr/share/icons/hicolor/512x512/apps/taiji-agent.png"
fi

if verify_packaged_config; then
  ok "Packaged non-secret config is active in the user runtime"
else
  runtime_issue "Packaged non-secret config is missing or not synchronized"
fi

if [ "${TAIJI_VERIFY_DESKTOP_SMOKE:-0}" = "1" ]; then
  if command -v taiji-agent >/dev/null 2>&1; then
    if command -v timeout >/dev/null 2>&1; then
      if TAIJI_DESKTOP_SMOKE_TEST=1 timeout 60 taiji-agent >/dev/null 2>&1; then
        ok "Electron desktop smoke test passed"
      else
        runtime_issue "Electron desktop smoke test failed"
      fi
    else
      warn "timeout not found; Electron desktop smoke test skipped"
    fi
  else
    runtime_issue "Electron desktop smoke test skipped because taiji-agent is not in PATH"
  fi
else
  warn "Electron desktop smoke test skipped; set TAIJI_VERIFY_DESKTOP_SMOKE=1 inside a graphical session to run it"
fi

agent_code="$(http_code "http://$AGENT_API_HOST:$AGENT_API_PORT/health")"
if [ "$agent_code" = "200" ]; then
  ok "Agent health returned HTTP 200 at $AGENT_API_HOST:$AGENT_API_PORT"
else
  warn "Agent health not reachable at $AGENT_API_HOST:$AGENT_API_PORT; start the desktop app and retry for runtime checks"
fi

webui_code="$(http_code "http://$WEBUI_HOST:$WEBUI_PORT/health")"
if [ "$webui_code" = "200" ]; then
  ok "WebUI health returned HTTP 200 at $WEBUI_HOST:$WEBUI_PORT"
  if verify_webui_api_payloads; then
    ok "WebUI settings and model-config APIs returned packaged desktop defaults"
  else
    runtime_issue "WebUI settings/model-config API check failed"
  fi
else
  warn "WebUI health not reachable at $WEBUI_HOST:$WEBUI_PORT; start the desktop app and retry for runtime checks"
fi

provider_keys=(OPENAI_API_KEY DEEPSEEK_API_KEY SILICONFLOW_API_KEY OPENROUTER_API_KEY ANTHROPIC_API_KEY GOOGLE_API_KEY GEMINI_API_KEY KIMI_API_KEY MOONSHOT_API_KEY DASHSCOPE_API_KEY XAI_API_KEY HF_TOKEN)
configured_key_count=0
for key in "${provider_keys[@]}"; do
  if [ -n "${!key:-}" ]; then
    configured_key_count=$((configured_key_count + 1))
  fi
done

if [ "$configured_key_count" -gt 0 ]; then
  ok "At least one model provider key is configured in the current environment"
else
  warn "No model provider key found; service checks do not prove real model conversation"
fi

echo
echo "Summary: OK=$ok_count WARN=$warn_count FAIL=$fail_count"
if [ "$fail_count" -gt 0 ]; then
  exit 1
fi
exit 0
