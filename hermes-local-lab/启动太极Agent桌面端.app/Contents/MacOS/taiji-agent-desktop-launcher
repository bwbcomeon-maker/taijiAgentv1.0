#!/usr/bin/env bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
LAB_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd -P)"
REPO_DIR="$(cd "$LAB_DIR/.." && pwd -P)"
APP_DIR="$REPO_DIR/apps/taiji-desktop"
ELECTRON_BIN="$APP_DIR/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron"
LOG_DIR="$HOME/.local/state/taiji-agent/logs"
LOG_FILE="$LOG_DIR/taiji-desktop-launcher.log"
TAIJI_SOURCE_MODE="${TAIJI_SOURCE_MODE:-formal}"

mkdir -p "$LOG_DIR"
exec >>"$LOG_FILE" 2>&1

show_error() {
  local message="$1"
  local escaped
  escaped="$(printf '%s' "$message" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  /usr/bin/osascript -e "display dialog \"$escaped\" with title \"太极 Agent 启动失败\" buttons {\"好\"} default button \"好\"" >/dev/null 2>&1 || true
}

check_source_gate() {
  local mode="$1"
  local repo_root git_top_raw git_top common_dir_raw common_dir canonical_root
  local branch head_commit main_commit status dirty worktree_kind

  case "$mode" in
    formal|development) ;;
    *)
      printf '[FAIL] unsupported source mode: %s\n' "$mode" >&2
      return 1
      ;;
  esac

  # Finder can execute this bundle but may reject a second shell script from
  # Documents with EPERM. Keep the same provenance gate in this process.
  unset GIT_DIR GIT_WORK_TREE GIT_COMMON_DIR GIT_INDEX_FILE
  unset GIT_OBJECT_DIRECTORY GIT_ALTERNATE_OBJECT_DIRECTORIES

  repo_root="$(cd "$REPO_DIR" && pwd -P)" || return 1
  git_top_raw="$(/usr/bin/git -C "$repo_root" rev-parse --show-toplevel 2>/dev/null)" \
    || { printf '[FAIL] repo root is not inside a Git worktree: %s\n' "$repo_root" >&2; return 1; }
  git_top="$(cd "$git_top_raw" && pwd -P)" || return 1
  [ "$repo_root" = "$git_top" ] \
    || { printf '[FAIL] repo root does not match git top-level\n' >&2; return 1; }

  common_dir_raw="$(/usr/bin/git -C "$git_top" rev-parse --git-common-dir 2>/dev/null)" \
    || { printf '[FAIL] cannot resolve git common dir\n' >&2; return 1; }
  case "$common_dir_raw" in
    /*) common_dir="$common_dir_raw" ;;
    *) common_dir="$git_top/$common_dir_raw" ;;
  esac
  common_dir="$(cd "$common_dir" && pwd -P)" || return 1
  canonical_root="$(cd "$common_dir/.." && pwd -P)" || return 1

  if [ "$git_top" = "$canonical_root" ]; then
    worktree_kind="primary"
  else
    worktree_kind="linked"
  fi
  branch="$(/usr/bin/git -C "$git_top" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  head_commit="$(/usr/bin/git -C "$git_top" rev-parse HEAD 2>/dev/null)" || return 1
  status="$(/usr/bin/git -C "$git_top" status --porcelain=v1 --untracked-files=all)" || return 1
  if [ -n "$status" ]; then dirty="1"; else dirty="0"; fi

  printf 'mode: %s\nsource_root: %s\nrepo: %s\ncanonical_root: %s\n' \
    "$mode" "$repo_root" "$git_top" "$canonical_root"
  printf 'worktree: %s\nbranch: %s\nhead: %s\ndirty: %s\n' \
    "$worktree_kind" "${branch:-detached}" "$head_commit" "$dirty"

  if [ "$mode" = "development" ]; then
    printf 'development source isolation gate passed\n'
    return 0
  fi

  [ "$worktree_kind" = "primary" ] \
    || { printf '[FAIL] formal source must use the primary worktree\n' >&2; return 1; }
  [ "$branch" = "main" ] \
    || { printf '[FAIL] formal source must be branch main\n' >&2; return 1; }
  main_commit="$(/usr/bin/git -C "$git_top" rev-parse refs/heads/main 2>/dev/null)" || return 1
  [ "$head_commit" = "$main_commit" ] \
    || { printf '[FAIL] formal source HEAD does not match local main\n' >&2; return 1; }
  [ "$dirty" = "0" ] \
    || { printf '%s\n[FAIL] formal source worktree is dirty\n' "$status" >&2; return 1; }

  printf 'canonical main source gate passed\n'
}

if ! check_source_gate "$TAIJI_SOURCE_MODE"; then
  show_error "源码状态校验未通过。正式启动仅允许干净的 main；开发调试请显式设置 TAIJI_SOURCE_MODE=development。"
  exit 1
fi

echo "========================================"
echo "太极 Agent 桌面端启动器"
echo "========================================"
echo "Time: $(date '+%Y-%m-%d %H:%M:%S')"
echo "App : $APP_DIR"
echo

if ! command -v npm >/dev/null 2>&1; then
  show_error "未找到 npm。请先安装 Node.js 20+。"
  exit 1
fi

cd "$APP_DIR"

if [ ! -d node_modules/electron ]; then
  echo "首次启动：正在安装 Electron 依赖..."
  if ! npm ci; then
    show_error "Electron 依赖安装失败。请查看本地日志。"
    exit 1
  fi
fi

if [ ! -x "$ELECTRON_BIN" ]; then
  show_error "Electron 启动文件不存在。请先安装桌面端依赖。"
  exit 1
fi

TAIJI_SOURCE_ROOT="$REPO_DIR"
SOURCE_INSTANCE_ID="$(
  printf '%s' "$TAIJI_SOURCE_ROOT" \
    | /usr/bin/shasum -a 256 \
    | /usr/bin/awk '{print substr($1, 1, 16)}'
)"
if [ -z "${TAIJI_DESKTOP_USER_DATA_DIR:-}" ]; then
  TAIJI_DESKTOP_USER_DATA_DIR="$HOME/.local/share/taiji-agent/source-instances/$SOURCE_INSTANCE_ID/electron-user-data"
fi
mkdir -p "$TAIJI_DESKTOP_USER_DATA_DIR"
TAIJI_SOURCE_COMMIT="unknown"
TAIJI_SOURCE_DIRTY="unknown"
if [ -x /usr/bin/git ] && /usr/bin/git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  TAIJI_SOURCE_COMMIT="$(/usr/bin/git -C "$REPO_DIR" rev-parse HEAD)"
  source_status="$(/usr/bin/git -C "$REPO_DIR" status --porcelain=v1 --untracked-files=normal)"
  if [ -n "$source_status" ]; then
    TAIJI_SOURCE_DIRTY="1"
  else
    TAIJI_SOURCE_DIRTY="0"
  fi
  unset source_status
fi
export TAIJI_AGENT_ROOT="$LAB_DIR"
export TAIJI_SOURCE_ROOT
export TAIJI_SOURCE_COMMIT
export TAIJI_SOURCE_DIRTY
export TAIJI_DESKTOP_USER_DATA_DIR

echo "Electron: $ELECTRON_BIN"
echo "Root: $TAIJI_SOURCE_ROOT"
echo "Commit: $TAIJI_SOURCE_COMMIT"
echo "Dirty: $TAIJI_SOURCE_DIRTY"
echo "Instance: $SOURCE_INSTANCE_ID"
echo "Electron data: $TAIJI_DESKTOP_USER_DATA_DIR"
RUNNER="$LOG_DIR/taiji-desktop-electron-runner-$SOURCE_INSTANCE_ID.sh"
cat >"$RUNNER" <<EOF
#!/usr/bin/env bash
set -euo pipefail
export PATH="$PATH"
export HOME="$HOME"
export USER="${USER:-$(id -un)}"
export LOGNAME="${LOGNAME:-$(id -un)}"
export SHELL="${SHELL:-/bin/zsh}"
export TMPDIR="${TMPDIR:-/tmp}"
export LANG="${LANG:-C.UTF-8}"
export LC_ALL="${LC_ALL:-C.UTF-8}"
export TAIJI_AGENT_ROOT="$LAB_DIR"
export TAIJI_SOURCE_ROOT="$TAIJI_SOURCE_ROOT"
export TAIJI_SOURCE_COMMIT="$TAIJI_SOURCE_COMMIT"
export TAIJI_SOURCE_DIRTY="$TAIJI_SOURCE_DIRTY"
export TAIJI_DESKTOP_USER_DATA_DIR="$TAIJI_DESKTOP_USER_DATA_DIR"
cd "$APP_DIR"
exec "$ELECTRON_BIN" "$APP_DIR" >>"$LOG_FILE" 2>&1
EOF
chmod +x "$RUNNER"

/usr/bin/osascript - "$RUNNER" <<'OSA'
on run argv
  do shell script quoted form of (item 1 of argv) & " >/dev/null 2>&1 &"
end run
OSA
echo "Electron launch delegated via osascript runner: $RUNNER"
exit 0
