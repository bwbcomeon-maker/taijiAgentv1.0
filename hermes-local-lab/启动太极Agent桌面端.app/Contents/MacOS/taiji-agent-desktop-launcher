#!/usr/bin/env bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

REPO_DIR="/Users/bwb/Documents/工作/taiji-agentv1.0"
APP_DIR="$REPO_DIR/apps/taiji-desktop"
LAB_DIR="$REPO_DIR/hermes-local-lab"
LOG_DIR="$HOME/.local/state/taiji-agent/logs"
LOG_FILE="$LOG_DIR/taiji-desktop-launcher.log"

mkdir -p "$LOG_DIR"
exec >>"$LOG_FILE" 2>&1

show_error() {
  local message="$1"
  local escaped
  escaped="$(printf '%s' "$message" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  /usr/bin/osascript -e "display dialog \"$escaped\" with title \"太极 Agent 启动失败\" buttons {\"好\"} default button \"好\"" >/dev/null 2>&1 || true
}

echo "========================================"
echo "太极 Agent 桌面端启动器"
echo "========================================"
echo "Time: $(date '+%Y-%m-%d %H:%M:%S')"
echo "App : $APP_DIR"
echo

if ! command -v npm >/dev/null 2>&1; then
  show_error "未找到 npm。请先安装 Node.js 20+。"
  exit 1
fi

cd "$APP_DIR"

if [ ! -d node_modules/electron ]; then
  echo "首次启动：正在安装 Electron 依赖..."
  if ! npm ci; then
    show_error "Electron 依赖安装失败。请查看本地日志。"
    exit 1
  fi
fi

export TAIJI_AGENT_ROOT="$LAB_DIR"
exec "$APP_DIR/node_modules/.bin/electron" "$APP_DIR"
