# Hermes Local Lab example configuration.
# Copy this file to .env only when you need to override defaults.
# Do not put real secrets in this example file or commit your .env.

# The scripts derive these directories from the repository location by default:
#   HERMES_HOME=<repo>/hermes-local-lab/hermes-home
#   HERMES_WORKSPACE=<repo>/hermes-local-lab/workspace
#   HERMES_WEBUI_STATE_DIR=<repo>/hermes-local-lab/hermes-home/webui
#   HERMES_WEBUI_DEFAULT_WORKSPACE=<repo>/hermes-local-lab/workspace
# Override them only if you intentionally want state outside this checkout.
# HERMES_HOME=
# HERMES_WORKSPACE=
# HERMES_WEBUI_STATE_DIR=
# HERMES_WEBUI_DEFAULT_WORKSPACE=

# Hermes Agent API Server.
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=18642
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=18642
API_SERVER_KEY=replace-with-a-random-local-dev-token
API_SERVER_CORS_ORIGINS=http://127.0.0.1:18787,http://localhost:18787
API_SERVER_MODEL_NAME=hermes-agent

# Hermes WebUI.
WEBUI_HOST=127.0.0.1
WEBUI_PORT=18787
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=18787
HERMES_WEBUI_CHAT_BACKEND=gateway
HERMES_WEBUI_GATEWAY_BASE_URL=http://127.0.0.1:18642
HERMES_WEBUI_GATEWAY_API_KEY=replace-with-the-same-value-as-API_SERVER_KEY

# Optional model/provider credentials. Leave unset unless you want real model calls.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# SILICONFLOW_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# KIMI_API_KEY=
# MOONSHOT_API_KEY=
# DASHSCOPE_API_KEY=
# GLM_API_KEY=
# XAI_API_KEY=
# HF_TOKEN=
# HERMES_API_BASE=

# Optional image understanding fallback for a custom OpenAI-compatible vision endpoint.
# AUXILIARY_VISION_API_KEY=
