[Desktop Entry]
Version=1.0
Type=Application
Name=清空太极 Agent 对话记录
Comment=备份并清空当前用户的太极 Agent 对话记录，不删除模型配置和 API Key
Exec=bash -c 'p="$1"; if [[ "$p" == file://* ]]; then p="${p#file://}"; p="$(python3 -c "import sys,urllib.parse; print(urllib.parse.unquote(sys.argv[1]))" "$p")"; fi; exec bash "$(dirname "$p")/04_目标终端_清空对话记录.sh"' taiji-clear-chat %k
Icon=taiji-agent
Terminal=true
Categories=Utility;
StartupNotify=false
